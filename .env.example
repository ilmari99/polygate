# === PolyGate configuration ===
# Copy to `.env` (the generator script creates one for you) and keep it SECRET.
# The real `.env` is gitignored and should be chmod 600.

# --- Account ---
# PRIVATE_KEY    : the private key of the wallet you use with Polymarket (your
#                  "EOA" - e.g. your MetaMask account). It signs your orders.
#                  Export it from your wallet, or create a fresh one with
#                  `python scripts/generate_wallet.py`.
# FUNDER_ADDRESS : your Polymarket deposit-wallet address (Profile -> Deposit,
#                  shown as "API use only"). It holds your funds and is the order
#                  maker. This is a different address from your EOA.
PRIVATE_KEY=
FUNDER_ADDRESS=

# --- Platform REST API protection ---
# Any random string. Send it as the `X-API-Key` header on every request.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PLATFORM_API_KEY=

# --- CLOB API credentials (filled in by `derive-creds`) ---
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# --- Server bind (optional) ---
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# --- Developer switch (optional, default off) ---
# When true, every order is simulated - never signed or broadcast. Used by the
# test suite and local development; leave unset/false for real trading.
# DRY_RUN=false
