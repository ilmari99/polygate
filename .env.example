# === PolyGate configuration ===
# Copy this file to `.env` and keep it SECRET.
# The real `.env` is gitignored and should be chmod 600.
#
# You do NOT have to edit this file by hand: you can instead start the server and
# open http://127.0.0.1:8000/setup to paste your keys into a local page. Either
# way the values below end up here.

# --- Account ---
# PRIVATE_KEY    : your signer key (an EOA private key). It signs your orders.
#                  On polymarket.com: Settings -> Account -> Private Key. (Or, if
#                  you connected your own wallet such as MetaMask, export its key.)
# FUNDER_ADDRESS : your Polymarket proxy-wallet address (Settings -> Profile ->
#                  Address). It holds your funds and is the order maker. This is a
#                  different address from your EOA.
PRIVATE_KEY=
FUNDER_ADDRESS=

# --- Platform REST API protection ---
# Leave this blank: PolyGate generates a key on first start and writes it here.
# It is the `X-API-Key` header you send on every request to the account endpoints.
PLATFORM_API_KEY=

# --- CLOB API credentials (derived automatically by the server on first start) ---
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# --- CLOB order signature type (optional; auto-detected) ---
# How your funder relates to your signer: 0 EOA, 1 POLY_PROXY (email/Google
# sign-up), 2 POLY_GNOSIS_SAFE (browser wallet), 3 POLY_1271 (deposit wallet).
# Leave blank: on first start PolyGate detects it from which maker holds your
# funds and writes it here. Set it explicitly only to override detection.
SIGNATURE_TYPE=

# --- Server bind (optional) ---
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# --- Developer switch (optional, default off) ---
# When true, every order is simulated - never signed or broadcast. Used by the
# test suite and local development; leave unset/false for real trading.
# DRY_RUN=false
